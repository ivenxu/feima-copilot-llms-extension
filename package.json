{
	"name": "copilot-more-models",
	"displayName": "Feima Copilot",
	"description": "Accelerating intent into execution - Alternative AI models for GitHub Copilot Chat: Claude, Gemini, GPT-4o, Qwen, DeepSeek, GLM, MiniMax, Kimi and more.",
	"version": "0.1.13",
	"publisher": "feima",
	"author": {
		"name": "Feima",
		"email": "support@feimacode.com"
	},
	"license": "MIT",
	"icon": "assets/ext-icon3.png",
	"repository": {
		"type": "git",
		"url": "https://github.com/feimacode/feima-copilot-llms-extension"
	},
	"bugs": {
		"url": "https://github.com/feimacode/feima-copilot-llms-extension/issues"
	},
	"homepage": "https://github.com/feimacode/feima-copilot-llms-extension#readme",
	"keywords": [
		"Copilot",
		"飞码扣",
		"Feimacode",
		"DeepSeek",
		"Qwen",
		"GLM",
		"MiniMax",
		"Kimi",
		"中文",
		"AI",
		"language-model",
		"authentication"
	],
	"categories": [
		"AI",
		"Programming Languages",
		"Chat"
	],
	"engines": {
		"vscode": "^1.85.0"
	},
	"enabledApiProposals": [
		"chatProvider",
		"inlineCompletionsAdditions",
		"languageModelThinkingPart"
	],
	"extensionDependencies": [
		"github.copilot-chat"
	],
	"activationEvents": [
		"onStartupFinished",
		"onLanguageModelChatProvider:feima"
	],
	"l10n": "./l10n",
	"main": "./dist/extension.js",
	"contributes": {
		"languageModelChatProviders": [
			{
				"vendor": "feima",
				"displayName": "Feima Copilot (Feima)"
			}
		],
		"commands": [
			{
				"command": "feima.signIn",
				"title": "Sign In",
				"category": "Feima"
			},
			{
				"command": "feima.signOut",
				"title": "Sign Out",
				"category": "Feima"
			},
			{
				"command": "feima.showAccount",
				"title": "View Account",
				"category": "Feima"
			},
			{
				"command": "feima.buyCredits",
				"title": "Buy Credits",
				"category": "Feima"
			}
		],
		"menus": {
			"commandPalette": [
				{
					"command": "feima.buyCredits",
					"when": "feima.isGlobalMarket"
				}
			]
		},
		"configuration": {
			"title": "Feima Copilot",
			"properties": {
				"feima.auth.baseUrl": {
					"type": "string",
					"default": "https://auth.feimacode.com",
					"markdownDescription": "OAuth2 authentication server base URL (overrides region default)",
					"scope": "machine-overridable"
				},
				"feima.api.baseUrl": {
					"type": "string",
					"default": "https://api.feimacode.com/v1",
					"markdownDescription": "Model inference API server base URL (overrides region default)",
					"scope": "machine-overridable"
				},
				"feima.auth.clientId": {
					"type": "string",
					"default": "vscode-feima-client",
					"markdownDescription": "OAuth2 client ID for authentication (overrides region default)",
					"scope": "machine-overridable"
				},
				"feima.auth.issuer": {
					"type": "string",
					"default": "https://auth.feimacode.com",
					"markdownDescription": "OAuth2 issuer URL (overrides region default)",
					"scope": "machine-overridable"
				},
				"feima.promotionUrl": {
					"type": "string",
					"default": "https://feimacode.com/promotion",
					"markdownDescription": "URL for the credits promotion page (shown when balance runs out)",
					"scope": "machine-overridable"
				},
				"feima.website.baseUrl": {
					"type": "string",
					"default": "https://feimacode.com",
					"markdownDescription": "Base URL for the Feima website (used for profile and activity log links)",
					"scope": "machine-overridable"
				},
				"feima.showQuotaInStatusBar": {
					"type": "boolean",
					"default": true,
					"description": "Show remaining request quota in status bar"
				},
				"feima.warnWhenQuotaLow": {
					"type": "number",
					"default": 50,
					"description": "Show warning when remaining requests drop below this number"
				}
			}
		},
		"icons": {
			"feima-logo": {
				"description": "Feima icon",
				"default": {
					"fontPath": "assets/feima-icons.woff",
					"fontCharacter": "\\f101"
				}
			}
		},
		"iconFonts": [
			{
				"id": "feima-font",
				"src": [
					{
						"path": "assets/feima-icons.woff",
						"format": "woff"
					}
				]
			}
		]
	},
	"scripts": {
		"vscode:prepublish": "npm run ext:package",
		"ext:build": "tsx .esbuild.ts",
		"ext:compile": "tsx .esbuild.ts --dev",
		"ext:watch": "tsx .esbuild.ts --watch --dev",
		"ext:build:global": "FEIMA_REGION=global tsx .esbuild.ts",
		"ext:package": "tsx .esbuild.ts",
		"ext:compile-tests": "tsc -p . --outDir out",
		"ext:watch-tests": "tsc -p . -w --outDir out",
		"ext:pretest": "npm run ext:compile-tests && npm run ext:compile && npm run ext:lint",
		"ext:lint": "eslint src --ext ts",
		"ext:test": "node ./out/test/runTest.js",
		"docs:dev": "cd docs && npm run dev",
		"docs:build": "cd docs && npm run build",
		"docs:preview": "cd docs && npm run preview",
		"build": "tsx .esbuild.ts",
		"build:cn": "FEIMA_REGION=cn tsx build/build.ts",
		"build:global": "FEIMA_REGION=global tsx build/build.ts",
		"build:all": "npm run build:cn && npm run build:global",
		"compile": "tsx .esbuild.ts --dev",
		"watch": "tsx .esbuild.ts --watch --dev",
		"package": "tsx .esbuild.ts",
		"package:cn": "FEIMA_REGION=cn npm run package",
		"package:global": "FEIMA_REGION=global npm run package",
		"compile-tests": "tsc -p . --outDir out",
		"watch-tests": "tsc -p . -w --outDir out",
		"pretest": "npm run compile-tests && npm run compile && npm run lint",
		"lint": "eslint src --ext ts",
		"test": "node ./out/test/runTest.js",
		"test:unit": "tsc -p src/test/unit/tsconfig.json --outDir out --noEmit false && mocha 'out/test/unit/**/*.test.js' --timeout 5000",
		"validate:vsix": "./build/validate-vsix.sh"
	},
	"devDependencies": {
		"@types/glob": "^8.1.0",
		"@types/mocha": "^10.0.6",
		"@types/node": "18.x",
		"@types/node-fetch": "^2.6.11",
		"@types/vscode": "^1.85.0",
		"@typescript-eslint/eslint-plugin": "^6.15.0",
		"@typescript-eslint/parser": "^6.15.0",
		"@vscode/test-electron": "^2.3.8",
		"@vscode/vsce": "^3.2.1",
		"esbuild": "^0.25.6",
		"eslint": "^8.56.0",
		"fantasticon": "^4.1.0",
		"glob": "^10.3.10",
		"mocha": "^10.2.0",
		"tsx": "^4.7.0",
		"typescript": "^5.3.3"
	},
	"dependencies": {
		"js-tiktoken": "^1.0.12",
		"node-fetch": "^2.7.0"
	}
}
